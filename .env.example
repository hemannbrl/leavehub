DJANGO_SECRET_KEY=dev-insecure-key-change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Leave the POSTGRES_* vars unset to run on SQLite with no database server.
# To use Postgres (e.g. `docker compose up -d`), uncomment these:
# POSTGRES_DB=leavehub
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# production only
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_HSTS_SECONDS=0
